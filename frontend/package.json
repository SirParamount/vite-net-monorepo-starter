{
  "name": "vite-monorepo",
  "private": true,
  "module": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n BACKEND,APP1,APP2 -c blue,magenta,green \"npm run dev:backend\" \"npm run dev:app1\" \"npm run dev:app2\"",
    "dev:app1": "npm run dev --workspace=app1",
    "dev:app2": "npm run dev --workspace=app2",
    "dev:backend": "dotnet watch run --project ../backend",
    "build": "npm run build:app1 && npm run build:app2",
    "build:app1": "npm run build --workspace=app1",
    "build:app2": "npm run build --workspace=app2",
    "preview:app1": "npm run preview --workspace=app1",
    "preview:app2": "npm run preview --workspace=app2",
    "test": "concurrently -k -n APP1,APP2 -c magenta,green \"npm run test:app1\" \"npm run test:app2\"",
    "test:watch": "concurrently -k -n APP1,APP2 -c magenta,green \"npm run test:watch:app1\" \"npm run test:watch:app2\"",
    "test:app1": "vitest run --config apps/app1/vite.config.ts",
    "test:app2": "vitest run --config apps/app2/vite.config.ts",
    "test:watch:app1": "vitest --config apps/app1/vite.config.ts --watch",
    "test:watch:app2": "vitest --config apps/app2/vite.config.ts --watch",
    "cert:generate": "tsx scripts/gen-local-cert.ts"
  },
  "devDependencies": {
    "@eslint/js": "9.26.0",
    "@tailwindcss/vite": "4.1.5",
    "@testing-library/react": "16.3.0",
    "@types/jest": "29.5.14",
    "@types/jest-axe": "3.5.9",
    "@types/node": "22.15.12",
    "@types/react": "19.1.3",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "@vitest/ui": "3.1.3",
    "axe-core": "4.10.3",
    "concurrently": "9.1.2",
    "eslint": "9.26.0",
    "eslint-config-prettier": "10.1.2",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "globals": "16.0.0",
    "jsdom": "26.1.0",
    "prettier": "3.5.3",
    "tailwindcss": "4.1.5",
    "tsx": "4.19.4",
    "vitest": "3.1.3",
    "vitest-axe": "0.1.0"
  }
}
